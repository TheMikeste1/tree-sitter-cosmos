    "filename": {
      "type": "PATTERN",
      "value": "\\w+\\.\\w+"
    },
    "identifier": {
      "type": "PATTERN",
      "value": "[a-zA-Z_\\$][a-zA-Z0-9_\\.]*"
    },
    "number": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "_hexadecimal_number"
        },
        {
          "type": "SEQ",
          "members": [
            {
              "type": "PATTERN",
              "value": "-?\\d+(\\.\\d*)?"
            },
            {
              "type": "CHOICE",
              "members": [
                {
                  "type": "PATTERN",
                  "value": "e\\d+"
                },
